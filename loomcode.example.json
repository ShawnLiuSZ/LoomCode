{
  "default_provider": "deepseek",
  "env": {
    "DEEPSEEK_API_KEY": "sk-xxxxxxxxxxxxxxxx",
    "MIMO_API_KEY": "",
    "OPENAI_API_KEY": ""
  },
  "plugins": [
    {
      "name": "my-tool",
      "command": "node",
      "args": ["./mcp-server.js"]
    }
  ],
  "permissions": {
    "shell_allowlist": ["git", "go", "make"]
  },
  "search": {
    "engine": "searxng"
  },
  "agent": {
    "planner_model": "deepseek-v4-pro"
  }
}
